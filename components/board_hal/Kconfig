menu "Board Configuration"

    choice BOARD_TYPE
        prompt "Board Driver"
        default BOARD_DRIVER_WAVESHARE_PHOTOPAINTER_73
        help
            Select the power management driver to use.

        config BOARD_DRIVER_WAVESHARE_PHOTOPAINTER_73
            bool "WaveShare PhotoPainter 7.3in"
            select PMIC_DRIVER_AXP2101
            select SDCARD_DRIVER_SDIO
            select SENSOR_DRIVER_SHTC3
            select RTC_DRIVER_PCF85063
            select EP_DRIVER_ED2208_GCA
            help
                Driver for WaveShare PhotoPainter 7.3in (Spectra 6) board.
                Includes AXP2101 PMIC initialization and SHTC3 sensor sleep management.
                SD card: SDIO interface (4-bit mode).

        config BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE02
            bool "Seeed XIAO EE02 (BQ24070)"
            select EP_DRIVER_ED2208_NCA
            help
                Driver for Seeed Studio XIAO EE02 board.
                Uses BQ24070 Linear Charger.
                Voltage is read via ADC. Percentage is estimated.
                Charging status via GPIO.
                No SD card support.
                AI rotation mode disabled due to limited PSRAM.

        config BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE04
            bool "Seeed XIAO EE04 (7.3in Spectra 6)"
            select EP_DRIVER_ED2208_GCA
            help
                Driver for Seeed Studio XIAO EE04 board (7.3" 6-color).
                Uses BQ24070 Linear Charger.
                Voltage is read via ADC. Percentage is estimated.
                Charging status via GPIO.
                No SD card support.
                AI rotation mode disabled due to limited PSRAM.

        config BOARD_DRIVER_SEEEDSTUDIO_RETERMINAL_E1002
            bool "Seeed reTerminal E1002 (Spectra E6)"
            select SDCARD_DRIVER_SPI
            select SENSOR_DRIVER_SHT40
            select RTC_DRIVER_PCF8563
            select EP_DRIVER_ED2208_GCA
            help
                Driver for Seeed reTerminal E1002 with 7.3" Spectra E6 display.
                Includes battery monitoring and deep sleep support.
                SD card: SPI interface.

        config BOARD_DRIVER_SEEEDSTUDIO_RETERMINAL_E1004
            bool "Seeed reTerminal E1004 (13.3in Spectra 6)"
            select SDCARD_DRIVER_SPI
            select SENSOR_DRIVER_SHT40
            select RTC_DRIVER_PCF8563
            select EP_DRIVER_ED2208_GCA
            help
                Driver for Seeed reTerminal E1004 with 13.3" Spectra 6 display (ED2208).
                Features ESP32-S3R8 (8MB Octal PSRAM), SY6974B I2C charger, PCF8563M RTC,
                SHT40 temperature/humidity sensor, SD card with TPS22916 power gating,
                buzzer, status LED, 3 physical buttons, 3 I2C touch buttons, and
                dual I2C buses. Battery ADC via GPIO1 with TPS22916 load switch.
                SD card: SPI interface.

    endchoice

    config USE_INTERNAL_FLASH_STORAGE
        bool "Use internal flash as storage (LittleFS)"
        default y if BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE02 || BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE04 || BOARD_DRIVER_SEEEDSTUDIO_RETERMINAL_E1002 || BOARD_DRIVER_SEEEDSTUDIO_RETERMINAL_E1004
        default n
        help
            Mounts a LittleFS partition from internal flash to use as storage.
            Disable this if your board has limited flash space (e.g. 4MB)
            and you don't have enough space for a storage partition.
            If disabled, the system will use a small RAM-based filesystem (MemFS)
            for temporary image processing instead.

endmenu
